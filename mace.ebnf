(* ===================================================== *)
(* 1. LEXICAL STRUCTURE                                  *)
(* ===================================================== *)

whitespace        = " " | "\t" | newline ;
newline           = "\n" | "\r\n" ;

comment            = "/=" , comment_body ;
comment_body       = block_comment_body | line_comment_body ;
block_comment_body = ? either an inline body whose nearest terminator is "=/"
                     before newline, or a vertical body started by a delimiter
                     line and terminated by a later "=/" ? ;
line_comment_body  = ? a comment body that ends at the next newline when no "=/" appears first ? ;
inline_description = "/#" , ws0 , description_text ;
description_text   = ? any character sequence up to but not including ',' ';' or newline ? ;

(* `;` terminates completed declaration entities in Mace. Record-style fields
   may use `,` or `;` separators, and inline descriptions may appear
   immediately before or after that separator. *)

ws0                = { whitespace | comment } ;
ws1                = ( whitespace | comment ) , ws0 ;

letter             = "A"…"Z" | "a"…"z" ;
digit              = "0"…"9" ;

identifier         = letter , { letter | digit | "_" } ;

string_literal     = single_string | double_string | block_string ;
single_string      = "'" , { single_character } , "'" ;
double_string      = '"' , { double_part } , '"' ;
block_string       = '"""' , { block_part } , '"""' ;
int_literal        = digit , { digit } ;
float_literal      = digit , { digit } , "." , digit , { digit } ;
boolean_literal    = "true" | "false" ;

character          = ? any Unicode scalar value ? ;
single_character   = ? any character except ' or newline or backslash ? | escape_sequence ;
double_part        = ? any character except " or newline or backslash or start of "$ (" ? | escape_sequence | interpolation ;
block_part         = ? any character sequence not containing '"""' or start of "$ (" ? | escape_sequence | interpolation ;
escape_sequence    = "\\" , ( "\\" | "'" | '"' | "n" | "r" | "t" ) ;
interpolation      = "$" , "(" , expression , ")" ;

(* ===================================================== *)
(* 2. TOP-LEVEL STRUCTURE                                *)
(* ===================================================== *)

mace_file
  = ws0 ,
    { import_declaration , ws0 } ,
    [ script_block , ws0 ] ,
    output_block ,
    ws0 ;

(* ===================================================== *)
(* 3. IMPORTS                                           *)
(* ===================================================== *)

import_declaration
  = "from" , ws1 , string_literal , ws1 ,
    "import" , ws1 , import_list ,
    ws0 , ";" ;

import_list
  = identifier , { ws0 , "," , ws0 , identifier } ;

(* ===================================================== *)
(* 4. SCRIPT BLOCK                                      *)
(* ===================================================== *)

script_block
  = script_delimiter ,
    ws0 ,
    { script_item , ws0 } ,
    script_delimiter ;

script_delimiter
  = "|" , "=" , "=" , "=" , { "=" } , "|" ;

script_item
  = declaration ;

declaration
  = variable_declaration
  | type_declaration
  | enum_declaration
  | schema_declaration
  | gen_doc_declaration
  | schema_doc_declaration ;

(* ===================================================== *)
(* 5. VARIABLE DECLARATIONS                             *)
(* ===================================================== *)

variable_declaration
  = injectable_variable_declaration
  | initialized_variable_declaration ;

injectable_variable_declaration
  = "injectable" , ws1 ,
    type_reference , ws1 ,
    identifier ,
    [ ws0 , "=" , ws0 , expression ] ,
    ws0 , ";" ;

initialized_variable_declaration
  = type_reference , ws1 ,
    identifier , ws0 ,
    "=" , ws0 ,
    expression ,
    ws0 , ";" ;

(* ===================================================== *)
(* 6. TYPE DECLARATIONS                                 *)
(* ===================================================== *)

type_declaration
  = "type" , ws1 ,
    identifier , ws0 ,
    ":" , ws0 ,
    type_reference ,
    [ ws0 , inline_description ] ,
    ws0 , ";" ;

gen_doc_declaration
  = "gen_doc" , ws1 ,
    identifier , ws0 ,
    "{" , ws0 ,
    { gen_doc_entry , ws0 } ,
    "}" ;

schema_doc_declaration
  = "schema_doc" , ws1 ,
    identifier , ws0 ,
    "{" , ws0 ,
    { schema_doc_entry , ws0 } ,
    "}" ;

(* `gen_doc` must appear after the target `type` declaration.
   `schema_doc` must appear after the target `schema` declaration. *)

gen_doc_entry
  = "summary" , ws0 , ":" , ws0 , string_literal , ws0 , ";"
  | "description" , ws0 , ":" , ws0 , block_string , ws0 , ";"
  | "props" , ws0 , ":" , ws0 , "{" , ws0 , { prop_entry , ws0 } , "}" , ws0 , ";" ;

schema_doc_entry
  = gen_doc_entry ;

prop_entry
  = identifier , ws0 , ":" , ws0 , string_literal , ws0 , ";" ;

(* ===================================================== *)
(* 7. ENUM DECLARATIONS                                 *)
(* ===================================================== *)

enum_declaration
  = "enum" , ws1 ,
    identifier , ws0 ,
    ":" , ws0 ,
    enum_backing_type , ws0 ,
    "{" , ws0 ,
    [ enum_member , { ws0 , "," , ws0 , enum_member } , [ ws0 , "," ] ] ,
    ws0 , "}" , ws0 , ";" ;

enum_backing_type
  = primitive_type ;

enum_member
  = identifier ,
    [ ws0 , "=" , ws0 , enum_member_value ] ;

enum_member_value
  = string_literal
  | int_literal
  | float_literal
  | boolean_literal ;

(* The current implementation accepts primitive backing-type syntax but
   validates only `string` and `int`. String and int enums may use implicit
   values. Implicit int values use zero-based declaration order. *)

(* ===================================================== *)
(* 8. SCHEMA DECLARATIONS                               *)
(* ===================================================== *)

schema_declaration
  = "schema" , ws1 ,
    identifier , ws0 ,
    ":" , ws0 ,
    record_type ,
    ws0 , ";" ;

record_type
  = "{" , ws0 ,
    { schema_field , ws0 } ,
    "}" ;

schema_field
  = identifier , [ "?" ] , ws0 ,
    ":" , ws0 ,
    type_reference ,
    field_terminator ;

field_terminator
  = ws0 , ( "," | ";" ) , [ ws0 , inline_description ]
  | [ ws0 , inline_description ] , [ ws0 , ( "," | ";" ) ] ;

(* ===================================================== *)
(* 9. TYPE REFERENCES                                   *)
(* ===================================================== *)

type_reference
  = primitive_type
  | array_type
  | union_type
  | variant_type
  | identifier ;

primitive_type
  = "string" | "int" | "float" | "boolean" ;

array_type
  = "array" , ws0 , "<" , ws0 ,
    type_reference ,
    ws0 , ">" ;

union_type
  = "union" , ws0 , "[" , ws0 ,
    type_reference , { ws0 , "," , ws0 , type_reference } ,
    ws0 , "]" ;

variant_type
  = "variant" , ws0 , "[" , ws0 ,
    type_reference , { ws0 , "," , ws0 , type_reference } ,
    ws0 , "]" ;

(* ===================================================== *)
(* 10. OUTPUT BLOCK                                      *)
(* ===================================================== *)

output_block
  = [ output_directive , ws0 , [ inline_doc_block , ws0 ] ] ,
    ws0 ,
    "{" , ws0 ,
    { output_item , ws0 } ,
    "}" ;

inline_doc_block
  = block_string ;

output_directive
  = "[" , ws0 ,
    directive_pair , { ws0 , "," , ws0 , directive_pair } ,
    ws0 , "]" ;

directive_pair
  = "output" , ws0 , "=" , ws0 , ( "data" | "schema" )
  | "schema_file" , ws0 , "=" , ws0 , string_literal
  | "schema" , ws0 , "=" , ws0 , identifier ;

(* If `output_directive` is omitted, the output mode defaults to `data`.
   `output = schema` must appear alone.
   `output = data` may appear alone, with `schema = <identifier>`,
   or with `schema_file = <string_literal>`, but not both. *)

output_item
  = output_field ;

output_field
  = identifier , [ "?" ] , ws0 ,
    ":" , ws0 ,
    expression ,
    field_terminator ;

output_schema_field
  = identifier , [ "?" ] , ws0 ,
    ":" , ws0 ,
    type_reference ,
    field_terminator ;

(* ===================================================== *)
(* 11. EXPRESSIONS (JS-LIKE, PURE, WITH PRECEDENCE)      *)
(* ===================================================== *)

expression
  = conditional_expression ;

primary_expression
  = identifier
  | member_access
  | int_literal
  | float_literal
  | string_literal
  | boolean_literal
  | array_literal
  | record_literal
  | self_reference
  | "(" , expression , ")" ;

member_access
  = primary_target , "." , identifier ;

primary_target
  = identifier
  | self_reference
  | "(" , expression , ")"
  | member_access ;

self_reference
  = "$self" , "." , identifier , { "." , identifier } ;

unary_expression
  = primary_expression
  | "!" unary_expression
  | "~" unary_expression
  | "+" unary_expression
  | "-" unary_expression ;

exponent_expression
  = unary_expression
  | unary_expression "**" exponent_expression ;

multiplicative_expression
  = exponent_expression
  | multiplicative_expression "*" exponent_expression
  | multiplicative_expression "/" exponent_expression
  | multiplicative_expression "%" exponent_expression ;

additive_expression
  = multiplicative_expression
  | additive_expression "+" multiplicative_expression
  | additive_expression "-" multiplicative_expression ;

shift_expression
  = additive_expression
  | shift_expression "<<" additive_expression
  | shift_expression ">>" additive_expression
  | shift_expression ">>>" additive_expression ;

relational_expression
  = shift_expression
  | relational_expression "<" shift_expression
  | relational_expression "<=" shift_expression
  | relational_expression ">" shift_expression
  | relational_expression ">=" shift_expression ;

equality_expression
  = relational_expression
  | equality_expression "==" relational_expression
  | equality_expression "!=" relational_expression
  | equality_expression "===" relational_expression
  | equality_expression "!==" relational_expression ;

bitwise_and_expression
  = equality_expression
  | bitwise_and_expression "&" equality_expression ;

bitwise_xor_expression
  = bitwise_and_expression
  | bitwise_xor_expression "^" bitwise_and_expression ;

bitwise_or_expression
  = bitwise_xor_expression
  | bitwise_or_expression "|" bitwise_xor_expression ;

logical_and_expression
  = bitwise_or_expression
  | logical_and_expression "&&" bitwise_or_expression ;

logical_or_expression
  = logical_and_expression
  | logical_or_expression "||" logical_and_expression ;

conditional_expression
  = logical_or_expression
  | logical_or_expression , ws0 , "?" , ws0 ,
    expression , ws0 , ":" , ws0 ,
    conditional_expression ;

(* ===================================================== *)
(* 12. LITERALS                                         *)
(* ===================================================== *)

array_literal
  = "[" , ws0 ,
    [ expression , { ws0 , "," , ws0 , expression } ] ,
    ws0 , "]" ;

record_literal
  = "{" , ws0 ,
    { record_field , ws0 } ,
    "}" ;

record_field
  = identifier , [ "?" ] , ws0 ,
    ":" , ws0 ,
    expression ,
    field_terminator ;
