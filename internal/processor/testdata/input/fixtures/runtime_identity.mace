|===|
type UserID: string;
type TeamSlug: string;
type Email: string;

schema UserProfile: {
  id: UserID,
  name: string,
  email: Email,
  team: TeamSlug,
};

schema SessionInput: {
  env: string,
  region: string,
  profile: UserProfile,
};

UserProfile example_user = {
  id: "USR-100",
  name: "Ada Lovelace",
  email: "ada@example.com",
  team: "platform",
};

SessionInput example_session = {
  env: "prod",
  region: "us-east-1",
  profile: example_user,
};
|===|
[output = schema]
{
  UserProfile: UserProfile,
  SessionInput: SessionInput,
}
