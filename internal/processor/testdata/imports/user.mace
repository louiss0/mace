from "./profile.mace" import Profile, Age;

|=================================================|
type Name = string;

injectable string name;

enum Personality: string { friendly, nice, rude }

Personality is_type  = Personality.nice;

schema User = { name: Name; profile: Profile; };

Name default_name = "Ada";

Age default_age = 30;

|=================================================|

[output = data]
{
  User: {
    name: default_name;
    is_type: is_type;
    profile: { age: default_age; };
  };
  foo: $self.User.profile.age;
  bar: ($self.foo + 5);
  baz: ($self.User.name);
}
