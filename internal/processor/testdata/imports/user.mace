|==================================================|
from "./profile.mace" import Profile, Age;

type Name: string;

injectable string name;

type Personality: choice["friendly", "nice", "rude"];

type Thing: variant[string, int];

type Status: choice[0, 1, 2];
type OtherStatus: choice[0.0, 0.1, 0.2];

Personality is_type = "nice";

schema User: { name: Name, profile: Profile, };

Name default_name = "Ada";

Age default_age = 30;

int num = 1 + 45;

|==================================================|

[output = data]
{
  User: {
    name: default_name,
    is_type: is_type,
    profile: { age: default_age, },
  },
  foo: $self.User.profile.age,
  bar: ($self.foo + 5),
  baz: ($self.User.name),
  bi: $self.bar,
}
